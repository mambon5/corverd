<VirtualHost *:80>
    ServerName coordinadoraverda.cat
    ServerAlias www.coordinadoraverda.cat
    
    # STATIC
    Alias /static /var/www/corverd/static
    <Directory /var/www/corverd/static>
        Require all granted
    </Directory>

    # MEDIA
    Alias /media /var/www/corverd/media
    <Directory /var/www/corverd/media>
        Require all granted
    </Directory>

    # WSGI
    WSGIDaemonProcess corverd python-path=/var/www/corverd python-home=/var/www/corverd/venv
    WSGIProcessGroup corverd
    WSGIScriptAlias / /var/www/corverd/corverd_project/wsgi.py

    <Directory /var/www/corverd/corverd_project>
        <Files wsgi.py>
            Require all granted
        </Files>
    </Directory>

    ErrorLog ${APACHE_LOG_DIR}/corverd_error.log
    CustomLog ${APACHE_LOG_DIR}/corverd_access.log combined
</VirtualHost>